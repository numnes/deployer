PORT=3000
DATABASE_URL=postgresql://postgres:deployer@localhost:5432/deployer
TYPEORM_SYNC=true
JWT_SECRET=troque-em-producao

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# ou: REDIS_URL=redis://127.0.0.1:6379

# Core
DEPLOYER_WORK_ROOT=/home/deployer/.local/share/deployer
DEPLOYER_CORE_DIR=/home/deployer/deployer/core

# Chave root-only para endpoints privilegiados (register / listar usuários).
# Gerada automaticamente no `deployer setup`. Enviada no header X-Deployer-Setup-Key.
DEPLOYER_SETUP_KEY=troque-em-producao

# Chave local para criptografar credenciais de nós remotos no Postgres.
# Gerada automaticamente pelo setup; mantenha estável entre restarts.
DEPLOYER_CLUSTER_SECRET=troque-em-producao

# CORS (separado por vírgula)
# Ex.: CORS_ORIGIN=http://localhost:3001,https://deployer.seudominio.com
CORS_ORIGIN=http://localhost:3001

