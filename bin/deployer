#!/usr/bin/env bash
# deployer CLI — wrapper for scripts in scripts/
set -euo pipefail

resolve_deployer_root() {
  if [[ -n "${DEPLOYER_ROOT:-}" ]]; then
    echo "$DEPLOYER_ROOT"
    return
  fi
  if [[ -f "${HOME}/.config/deployer/root" ]]; then
    cat "${HOME}/.config/deployer/root"
    return
  fi
  local script
  script="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || true)"
  if [[ -z "$script" ]]; then
    script="${BASH_SOURCE[0]}"
  fi
  local dir
  dir="$(cd "$(dirname "$script")/.." && pwd)"
  echo "$dir"
}

ROOT="$(resolve_deployer_root)"

if [[ ! -d "$ROOT/scripts" ]]; then
  echo "deployer: invalid install directory: $ROOT" >&2
  echo "Set DEPLOYER_ROOT or reinstall with scripts/install.sh" >&2
  exit 1
fi

cmd="${1:-help}"
shift || true

confirm_down() {
  if [[ "${DEPLOYER_YES:-}" == "1" || "${1:-}" == "-y" || "${1:-}" == "--yes" ]]; then
    return 0
  fi
  echo ""
  echo "⚠  This will shut down deployer:"
  echo "   • API (PM2: deployer-api)"
  echo "   • Docker containers (Postgres, Redis, Front)"
  echo ""
  read -r -p "Continue? [y/N] " ans
  if [[ ! "$ans" =~ ^[yY]$ ]]; then
    echo "Cancelled."
    exit 0
  fi
}

case "$cmd" in
  setup|up|start)
    exec bash "${ROOT}/scripts/dev-up.sh" "$@"
    ;;
  down|stop)
    confirm_down "$@"
    exec bash "${ROOT}/scripts/dev-down.sh" "$@"
    ;;
  restart)
    confirm_down "$@"
    bash "${ROOT}/scripts/dev-down.sh"
    exec bash "${ROOT}/scripts/dev-up.sh" "$@"
    ;;
  status)
    echo "=== Deployer ($ROOT) ==="
    ENV_FILE="${ROOT}/server/.env"
    if [[ -f "$ENV_FILE" ]]; then
      api_port="$(grep -E '^PORT=' "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '[:space:]')"
      front_port="$(grep -E '^CORS_ORIGIN=' "$ENV_FILE" 2>/dev/null | tail -1 | sed 's/.*://' | tr -d '[:space:]')"
      pg_port="$(grep -E '^DATABASE_URL=' "$ENV_FILE" 2>/dev/null | tail -1 | sed -n 's/.*:\([0-9]*\)\/deployer.*/\1/p')"
      redis_port="$(grep -E '^REDIS_PORT=' "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '[:space:]')"
      echo ""
      echo "Ports (from server/.env):"
      echo "  API:      ${api_port:-?}"
      echo "  Front:    ${front_port:-?}"
      echo "  Postgres: ${pg_port:-?}"
      echo "  Redis:    ${redis_port:-?}"
    fi
    echo ""
    echo "Docker:"
    if docker ps -a --filter 'name=deployer-' --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null | grep -q deployer; then
      docker ps -a --filter 'name=deployer-' --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
    else
      echo "  (no deployer-* containers)"
    fi
    echo ""
    echo "PM2:"
    if command -v pm2 >/dev/null 2>&1; then
      pm2 describe deployer-api 2>/dev/null | grep -E 'status|name|script path' || echo "  deployer-api is not running"
    else
      npx --yes pm2 describe deployer-api 2>/dev/null | grep -E 'status|name|script path' || echo "  deployer-api is not running"
    fi
    ;;
  logs)
    target="${1:-api}"
    case "$target" in
      api)
        if command -v pm2 >/dev/null 2>&1; then
          exec pm2 logs deployer-api --lines 100
        else
          exec npx --yes pm2 logs deployer-api --lines 100
        fi
        ;;
      front)
        exec docker logs -f --tail 100 deployer-front
        ;;
      *)
        echo "Usage: deployer logs [api|front]" >&2
        exit 1
        ;;
    esac
    ;;
  update|pull)
    echo "[deployer] Updating repository at $ROOT..."
    git -C "$ROOT" pull --ff-only
    deployer_in_path="$(command -v deployer 2>/dev/null || true)"
    if [[ -n "$deployer_in_path" ]]; then
      export DEPLOYER_BIN_DIR="$(dirname "$deployer_in_path")"
    fi
    bash "${ROOT}/scripts/sync-cli.sh"
    echo "[deployer] OK — executable and scripts updated"
    ;;
  project)
    sub="${1:-help}"
    shift || true
    case "$sub" in
      init|setup)
        exec bash "${ROOT}/scripts/project-init.sh" "$@"
        ;;
      help|-h|--help)
        exec bash "${ROOT}/scripts/project-init.sh" --help
        ;;
      *)
        echo "deployer: unknown project command: $sub" >&2
        echo "Run: deployer project init --help" >&2
        exit 1
        ;;
    esac
    ;;
  root|path)
    echo "$ROOT"
    ;;
  help|-h|--help)
    cat <<EOF
deployer — local Deployer stack management

Usage: deployer <command> [options]

Commands:
  setup, up, start   Start Postgres, Redis, front (Docker) and API (PM2)
  down, stop         Stop API and containers (asks for confirmation)
  restart            down + setup (asks for confirmation)
  status             Show container and API status
  logs [api|front]   Follow API (PM2) or front (Docker) logs
  project init       Copy GitHub Actions + deployer.yaml into an app repo
  update, pull       git pull + refresh CLI symlink and scripts
  root, path         Print install directory
  help               Show this help

Options:
  down/restart -y, --yes   Skip confirmation
  DEPLOYER_YES=1           Same as above

Install: curl -fsSL .../scripts/install.sh | bash
Directory: $ROOT
EOF
    ;;
  *)
    echo "deployer: unknown command: $cmd" >&2
    echo "Run: deployer help" >&2
    exit 1
    ;;
esac
